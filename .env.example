# ─────────────────────────────────────────────────────────────
# DulyHired — Environment Variables
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────
# Project URL — found in Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon/publishable key — safe for client-side (Supabase RLS protects data)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_pub_...

# Service role key — server-side only (full access to all tables)
NEXT_PUBLIC_SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIs...

# Required for one-time DB schema setup (api/auth/setup-db)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# ── Careerjet API ────────────────────────────────────────────
# Your Careerjet affiliate ID / API key
CAREER_JET_API_KEY=1ee108...

# IP address to send with Careerjet API requests (careerjet requires user_ip)
CAREERJET_USER_IP=182.187.154.171

# ── Resend (Email) ───────────────────────────────────────────
# Used by the contact form to send emails to support@dulyhired.com
RESEND_API_KEY=re_...

# ── Adzuna (optional backfill) ───────────────────────────────
# Only needed if running the programmatic job backfill
ADZUNA_APP_ID=your_app_id
ADZUNA_API_KEY=your_api_key
